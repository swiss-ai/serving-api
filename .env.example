# Copy this to .env (the Makefile does this automatically on first run).
# Fill in the REPLACE_WITH_* placeholders with values from
# rob-poc/serving-api/dev/secrets.yaml. Never put prod values here —
# the Makefile's _guard-local-db will refuse non-local DATABASE_URL.

# ── Local Postgres (matches what `make db-up` spins up) ──────────────────────
DATABASE_URL=postgresql://serving:serving@localhost:5433/serving

# ── OIDC provider selector (issue #58) ───────────────────────────────────────
# AUTH_PROVIDER picks the active IdP: `auth0` or `authentik`. Both credential
# sets can be present at once so a prod cutover/rollback is a single env change
# with no rebuild. When the AUTHENTIK_* set is unset it falls back to the
# AUTH0_* values below, so an env that already holds Authentik values under the
# legacy AUTH0_* names just needs AUTH_PROVIDER=authentik.
AUTH_PROVIDER=authentik

# ── Auth0 credential set ─────────────────────────────────────────────────────
# The backend and frontend resolve userinfo/token/end-session endpoints from
# the active issuer via OIDC discovery, so only issuer/client values matter.
# `make run` uses these for a real login; `make auth-run` sets
# DEV_AUTH_BYPASS=true and accepts a dev session without contacting the IdP.
AUTH0_DOMAIN=auth.swissai.svc.cscs.ch
AUTH0_ISSUER=https://auth.swissai.svc.cscs.ch/application/o/serving-api-dev/
AUTH0_CLIENT_ID=REPLACE_WITH_AUTH0_CLIENT_ID
AUTH0_CLIENT_SECRET=REPLACE_WITH_AUTH0_CLIENT_SECRET

# ── Authentik credential set (optional) ──────────────────────────────────────
# Leave blank locally to inherit the AUTH0_* values above. Set explicitly when
# you want both providers configured side by side (as in prod).
AUTHENTIK_ISSUER=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=

AUTH_SECRET=REPLACE_WITH_RANDOM_STRING
AUTH_TRUST_HOST=true

VITE_AUTH0_CLIENT_ID=REPLACE_WITH_VITE_AUTH0_CLIENT_ID
VITE_AUTH0_DOMAIN=auth.swissai.svc.cscs.ch

# ── OpenTela / OCF (peer discovery + LLM routing) ────────────────────────────
# Point at the dev OpenTela head for live model discovery, or use
# OTELA_FIXTURE_PATH (set by `make dummy-run`) to read a static snapshot.
OCF_HEAD_ADDR=http://148.187.108.177:8092

# ── Langfuse (observability — optional; leave blank to disable) ──────────────
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── CSCS L1 passthrough (optional; leave blank to disable) ───────────────────
# When both are set, requests for L1-hosted Apertus models forward here
# instead of OpenTela. See backend/services/cscs_l1_service.py.
CSCS_L1_BASE_URL=
CSCS_L1_API_KEY=

# ── Logfire (observability — optional) ───────────────────────────────────────
LOGFIRE_TOKEN=
