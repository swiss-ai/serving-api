---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";

export const prerender = false;

const faqs = [
  {
    q: "Can I use this in my project?",
    a: "Yes, as long as it's an academic project, we should be able to grant you access.",
  },
  {
    q: "Can I use this for commercial or startup use?",
    a: 'No, this is for non-commercial use only. Please reach out at <a class="text-indigo-600 dark:text-indigo-400 underline" href="https://apertvs.ai/contact/" target="_blank" rel="noopener noreferrer">apertvs.ai/contact/</a>, including some details and we will forward your request to the right internal team or industry partners',
  },
  {
    q: "Can I launch any model?",
    a: 'Yes, see <a class="text-indigo-600 dark:text-indigo-400 underline" href="https://github.com/swiss-ai/model-launch" target="_blank" rel="noopener noreferrer">model launch</a>. This usually requires a CSCS GPU grant. Compute grants come in two tiers: small (&lt;32k GPU hrs) and large (&gt;500k GPU hrs). See the <a class="text-indigo-600 dark:text-indigo-400 underline" href="https://www.swiss-ai.org/compute-grants" target="_blank" rel="noopener noreferrer">compute grants process</a>.',
  },
  {
    q: "Is my institution enabled?",
    a: 'Members of supported Swiss institutions are auto-enabled, getting an active budget on first sign-in. See the current list of <a class="text-indigo-600 dark:text-indigo-400 underline" href="https://github.com/swiss-ai/serving-api/blob/main/backend/swiss_domains.json" target="_blank" rel="noopener noreferrer">enabled institutions</a>. If yours is not listed, please <a class="text-indigo-600 dark:text-indigo-400 underline" href="https://apertvs.ai/contact/" target="_blank" rel="noopener noreferrer">contact us</a>.',
  },
  {
    q: "I'm at a non-Swiss university, can I get access?",
    a: "Yes, but service is prioritised in this order: <br /><br />(1) ETH and EPFL Apertus-related projects, <br />(2) Swiss AI-related institutions, <br />(3) other global academic institutions.",
  },
  {
    q: "I'm running a hackathon or sprint, can we get access?",
    a: 'Possibly. If it\'s academic and focused on Apertus, please reach out at <a class="text-indigo-600 dark:text-indigo-400 underline" href="https://apertvs.ai/contact/" target="_blank" rel="noopener noreferrer">apertvs.ai/contact/</a>.',
  },
  {
    q: "I can't access the Chat because I'm not on the network. What can I do?",
    a: 'If you have API access, try running Open WebUI locally: see the <a class="text-indigo-600 dark:text-indigo-400 underline" href="https://serving.swissai.svc.cscs.ch/guides/01-getting-started/openwebui" target="_blank" rel="noopener noreferrer">Open WebUI guide</a>. Otherwise, we can whitelist your institution or VPN IP range; please <a class="text-indigo-600 dark:text-indigo-400 underline" href="https://apertvs.ai/contact/" target="_blank" rel="noopener noreferrer">contact us</a>.',
  },
  {
    q: "I would like to collaborate on an academic project, is this possible?",
    a: 'Please reach out at <a class="text-indigo-600 dark:text-indigo-400 underline" href="https://apertvs.ai/contact/" target="_blank" rel="noopener noreferrer">apertvs.ai/contact/</a>.',
  },
  {
    q: "Do you store my prompts and responses?",
    a: 'For the <strong>API</strong>: no. We do not store prompt or response content. We keep only metadata logs (e.g. userid, input/output token counts, model, timestamp) for capacity planning and abuse prevention.<br /><br />For the internal facing <strong>Chat app</strong>: yes, your conversation history is retained so you can return to past chats. This is important for the Apertus team development and testing various model types. Your chats are not extracted and used for training. To request deletion of your chat history, please <a class="text-indigo-600 dark:text-indigo-400 underline" href="https://apertvs.ai/contact/" target="_blank" rel="noopener noreferrer">contact us</a>.',
  },
  {
    q: "Do you train models on my data?",
    a: "No. We do not use your prompts or responses to train or fine-tune models. All data used to train Apertus data has strict data standards. ",
  },
  {
    q: "How long do you retain data?",
    a: 'API metadata logs (token counts, model, timestamp) are kept indefinitely for operations and abuse prevention. Individual chat history is retained until you delete it via OpenWebUI settings or you delete your account, to do this please contact us. For specific data retention questions, please <a class="text-indigo-600 dark:text-indigo-400 underline" href="https://apertvs.ai/contact/" target="_blank" rel="noopener noreferrer">contact us</a>.',
  },
  {
    q: "For the Chat application, where is my data processed and stored?",
    a: 'The platform runs on Swiss infrastructure (CSCS) which is based in Lugano. This includes the entire application, including the web application, API, database and storage.',
  },
  {
    q: "Can I send personal, confidential, or sensitive data?",
    a: 'Do not send personal, confidential, or otherwise sensitive data (e.g. personally identifiable information). The platform is a research service and is not intended for processing such data. If your project has specific data-protection requirements (FADP/GDPR), please <a class="text-indigo-600 dark:text-indigo-400 underline" href="https://apertvs.ai/contact/" target="_blank" rel="noopener noreferrer">contact us</a> first.',
  },
  {
    q: "What models are available?",
    a: 'You can list the currently available models on the webpage or via the <code>/v1/models</code> endpoint, or pick from the model selector in the Chat app.',
  },
  {
    q: "Are there rate limits or usage budgets?",
    a: 'Yes. Each user/institution has a usage budget, and requests may be rate-limited to keep the service fair and available. If you need a higher limit for a project, please <a class="text-indigo-600 dark:text-indigo-400 underline" href="https://apertvs.ai/contact/" target="_blank" rel="noopener noreferrer">contact us</a>.',
  },
  {
    q: "How do I get or reset my API key?",
    a: 'You can create and reset your key on the <a class="text-indigo-600 dark:text-indigo-400 underline" href="/api_key">API key page</a>. Currently there is only 1 API key available per user.',
  },
  {
    q: "Can I use OpenAI-compatible tools and SDKs?",
    a: 'Yes. The API is OpenAI-compatible, so it works with the OpenAI SDKs, LangChain, Open WebUI and similar tools — just point the base URL at our endpoint (<code>.../v1</code>) and use your API key.',
  },
  {
    q: "Can I share a chat publicly?",
    a: 'No. Chats can only be shared with specific signed-in users or a group via the <strong>Share</strong> button — there is no public link, since all access requires an SSO login. Pasting a chat URL won\u2019t work for others; use the Share dialog instead.',
  },
  {
    q: "Can I share a chat publicly?",
    a: 'No. Chats can only be shared with specific signed-in users or a group via the <strong>Share</strong> button — there is no public link, since all access requires an SSO login. Pasting a chat URL won\u2019t work for others; use the Share dialog instead.',
  },
  {
    q: "How should I cite or refer to the service in a paper, proposal, or other document?",
    a: Please refer to the service as <strong>Swiss AI Serving</strong> and cite the OpenTela project that powers it using the following BibTeX entry: <pre><code>@inproceedings{318577, author = {Xiaozhe Yao and Youhe Jiang and Ilia Badanin and Qinghao Hu and Robert Matthew Smith and Binhang Yuan and Imanol Schlag and Eiko Yoneki and Ana Klimovic}, title = {{OpenTela}: Unifying Decentralized Computing Resources for Heterogeneous {LLM} Serving (Operational Systems)}, booktitle = {20th USENIX Symposium on Operating Systems Design and Implementation (OSDI 26)}, year = {2026}, isbn = {978-1-939133-55-7}, address = {Seattle, WA}, pages = {1821--1838}, url = {https://www.usenix.org/conference/osdi26/presentation/yao}, publisher = {USENIX Association}, month = jul }</code></pre>,
  },
];
---

<PageLayout title="FAQ" description="Frequently asked questions about the Swiss AI Research Platform">
  <Container>
    <div class="space-y-12 py-8">
      <div class="animate text-center">
        <h1 class="text-4xl md:text-5xl font-bold gradient-text mb-4">
          Frequently Asked Questions
        </h1>
        <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
          Common questions about access and use of the Swiss AI Platform
        </p>
      </div>

      <div class="space-y-6">
        {faqs.map((faq) => (
          <div class="animate card p-8">
            <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-3">
              {faq.q}
            </h2>
            <p class="text-slate-600 dark:text-slate-300 leading-relaxed" set:html={faq.a} />
          </div>
        ))}
      </div>
    </div>
  </Container>
</PageLayout>
